{
  "rewrites": [
    {
      "source": "/api/uploads/:path*",
      "destination": "https://mallusmart.com/Content/uploads/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://mallusmart.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
