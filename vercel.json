{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "^/api/uploads/(.*)",
      "destination": "https://api.mallusmart.com/uploads/$1"
    },
    {
      "source": "^/api/(.*)",
      "destination": "https://api.mallusmart.com/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
